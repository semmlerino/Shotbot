{
  "include_patterns": [
    "*.py",
    "*.json",
    "*.toml",
    "*.yml",
    "*.yaml",
    "*.ini",
    "*.cfg",
    "requirements*.txt",
    "pyproject.toml"
  ],
  "exclude_patterns": [
    "test_*.py",
    "*_test.py",
    "tests/",
    "AGENTS.md",
    "CLAUDE.md",
    "bundle_app.py",
    "transfer_cli.py",
    "decode_app.py",
    "transfer_config.json",
    "*.log",
    "*.tmp",
    "coverage*.json",
    "encoded_app_*.txt",
    "encoded_app_*.json",
    "encoded_releases/*",
    ".post-commit-output/*",
    "bundle_workflow_template/*"
  ],
  "exclude_dirs": [
    "tests",
    "test",
    "__pycache__",
    ".git",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    "venv",
    "venv_py311",
    ".venv",
    "env",
    ".env",
    "test_venv",
    ".skylos",
    ".github",
    ".claude",
    ".serena",
    ".vscode",
    ".idea",
    ".archive",
    "archive",
    "docs",
    "dev-tools",
    "examples",
    "build",
    "dist",
    "node_modules",
    "encoded_releases",
    ".post-commit-output",
    "bundle_workflow_template"
  ],
  "max_file_size_mb": 10,
  "chunk_size_kb": 5120,
  "output_dir": "encoded_releases"
}
